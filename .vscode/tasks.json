{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Flutter Windows",
			"type": "shell",
			"command": "cd bsafe/flutter_app && flutter run -d windows",
			"isBackground": true,
			"problemMatcher": [
				"$dart-build"
			],
			"group": "build"
		},
		{
			"label": "Run Flutter Windows App",
			"type": "shell",
			"command": "cd bsafe/flutter_app; flutter run -d windows",
			"isBackground": true,
			"problemMatcher": [
				"$dart-build"
			],
			"group": "build"
		}
	]
}